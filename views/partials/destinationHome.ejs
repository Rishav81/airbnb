<section>
  <div class="max-w-[90rem] mx-auto px-6">

    <!-- Heading -->
    <div class="mb-2">
      <h2 class="text-xl md:text-2xl font-bold text-white tracking-tight">
        Explore by
        <span class="bg-gradient-to-r from-red-500 to-pink-500 bg-clip-text text-transparent">
          Destination
        </span>
      </h2>
      <div class="w-16 h-1 bg-gradient-to-r from-red-500 to-pink-500 mt-1 rounded-full"></div>
    </div>

    <!-- Scroll Container -->
    <div class="flex gap-2 overflow-x-auto pb-6 
                scroll-smooth snap-x snap-mandatory 
                scrollbar-hide">

      <% destinations.forEach(dest => { %>

      <a
        href="/home-list"
        class="group block relative min-w-[160px] md:min-w-[180px] lg:min-w-[200px] 
               snap-start rounded-2xl overflow-hidden 
               shadow-md hover:shadow-2xl hover:-translate-y-1
               transition-all duration-500 ease-out will-change-transform">

        <!-- Image -->
        <img
          src="<%= destinationImages[dest] %>"
          loading="lazy"
          class="w-full h-52 object-cover 
                 group-hover:scale-105 
                 transition-transform duration-700 ease-out 
                 will-change-transform"
        />

        <!-- Overlay -->
        <div
          class="absolute inset-0 
                 bg-gradient-to-t from-black/70 via-black/20 to-transparent
                 group-hover:from-black/60
                 transition-all duration-500 ease-out">
        </div>

        <!-- Bottom Content -->
        <div class="absolute bottom-4 left-4 text-white">
          <h3 class="font-semibold text-sm sm:text-base">
            <%= dest %>
          </h3>
          <p class="text-xs text-gray-200">
            <%= destinationCounts[dest] %> homes
          </p>
        </div>

      </a>

      <% }) %>
    </div>
  </div>
</section>