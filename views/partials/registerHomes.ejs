<section class="pt-6 md:pt-28 pb-6 min-h-screen">
  <div class="mx-auto max-w-[90rem] px-6">

    <!-- Section Header -->
    <div class="mb-6">
      <h2 class="text-xl md:text-2xl font-bold text-white tracking-tight">

        <% if (location) { %>
          Homes in
          <span class="bg-gradient-to-r from-red-500 to-pink-500 bg-clip-text text-transparent">
            <%= location %>
          </span>
        <% } else { %>
          Registered
          <span class="bg-gradient-to-r from-red-500 to-pink-500 bg-clip-text text-transparent">
            Airbnb
          </span>
          Homes
        <% } %>

      </h2>

      <div class="w-16 h-1 bg-gradient-to-r from-red-500 to-pink-500 mt-3 rounded-full"></div>
    </div>

    <!-- GRID -->
    <div>
      <ul class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-2">

        <% registeredHomes.forEach(home => { %>
          <% const isFav = favouriteIds.includes(String(home._id)); %>

          <li class="group relative rounded-2xl overflow-hidden 
                     bg-white/[0.03] 
                     border border-white/5
                     shadow-lg shadow-black/40
                     hover:shadow-2xl hover:shadow-black/60
                     hover:-translate-y-1
                     transition-all duration-300 ease-out">

            <!-- IMAGE + OVERLAYS -->
            <div class="relative w-full h-52 overflow-hidden rounded-2xl">
              
              <a href="/home-list/<%= home._id %>">
                <img
                  src="<%= home.houseImg %>"
                  loading="lazy"
                  alt="<%= home.houseName %>"
                  class="w-full h-full object-cover 
                         transition-transform duration-700 ease-out 
                         group-hover:scale-110"
                />

                <!-- Dark Gradient Overlay -->
                <div class="absolute inset-0 
                            bg-gradient-to-t 
                            from-black/80 via-black/30 to-transparent
                            opacity-90 group-hover:opacity-100
                            transition duration-300">
                </div>

                <!-- Rating -->
                <div class="absolute top-3 left-3 
                            bg-black/60 backdrop-blur-md 
                            px-2.5 py-1 
                            rounded-full 
                            flex items-center gap-1 
                            text-xs font-semibold text-white
                            shadow-md shadow-black/40">

                  <span class="text-yellow-400">★</span>
                  <%= home.houseRating %>
                </div>

              </a>

              <!-- Favourite Button -->
              <button
                type="button"
                data-id="<%= home._id %>"
                class="fav-btn absolute top-3 right-3 z-10 
                       bg-black/40 backdrop-blur-md 
                        rounded-full 
                       shadow-md shadow-black/40
                       hover:scale-110 hover:bg-black/60
                       active:scale-95
                       transition-all duration-300"
              >
                <span class="heart text-lg <%= isFav ? 'text-red-500' : 'text-gray-400' %>">
                  <%= isFav ? "❤️" : "🤍" %>
                </span>
              </button>

              <!-- Bottom Content -->
<div class="absolute bottom-3 left-3 right-3 text-white">
      <h3 class="font-semibold text-sm sm:text-base line-clamp-1">
        <%= home.houseName %>
      </h3>

      <p class="text-xs text-gray-200 line-clamp-1">
        📍 <%= home.houseLocation %>
      </p>

      <!-- Price + Rating -->
      <div class="flex justify-between items-center mt-2">

        <span class="text-xs sm:text-sm font-bold">
          ₹<%= home.houseRent %>
          <span class="font-normal text-gray-200">/night</span>
        </span>

       

      </div>
    </div>
            </div>

          </li>

        <% }) %>

      </ul>
    </div>

  </div>
</section>