<%- include('../partials/head') %>
</head>

<body class="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 
             flex items-center justify-center px-4 relative overflow-hidden">

  <%- include('../partials/nav') %>

  <!-- Soft Background Glow -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-[-150px] left-1/2 -translate-x-1/2 
                w-[600px] h-[600px] bg-red-500/20 blur-3xl rounded-full"></div>
  </div>

  <!-- Signup Card -->
  <div class="w-full mt-20 md:mt-0 max-w-md relative">
    <div class="rounded-3xl p-8 
                bg-white/10 backdrop-blur-xl 
                border border-white/20 
                shadow-2xl shadow-black/40
                transition-all duration-500">

      <!-- Title -->
      <h1 class="text-3xl font-extrabold text-center 
                 bg-gradient-to-r from-red-500 to-pink-500 
                 bg-clip-text text-transparent">
        Create Account
      </h1>

      <p class="text-sm text-gray-400 text-center mt-2">
        Join and start booking your stays
      </p>

      <!-- Form -->
      <form action="/signup" method="POST" class="mt-8 space-y-6">

        <!-- Full Name -->
        <div class="space-y-1">
          <input type="text" name="userName" required
            value="<%= oldInput.userName || '' %>"
            placeholder="Enter your full name"
            class="w-full rounded-xl bg-white/20 px-4 py-3 text-sm text-white placeholder-gray-400 border
              <%= errors.userName ? 'border-red-400 focus:ring-red-400/40' : 'border-white/20 focus:ring-red-400/30' %>
              focus:outline-none focus:ring-2 focus:border-transparent
              transition-all duration-300">

          <% if (errors.userName) { %>
            <p class="text-red-400 text-xs px-2"><%= errors.userName.msg %></p>
          <% } %>
        </div>

        <!-- Email -->
        <div class="space-y-1">
          <input type="email" name="email" required
            value="<%= oldInput.email || '' %>"
            placeholder="Enter your email"
            class="w-full rounded-xl bg-white/20 px-4 py-3 text-sm text-white placeholder-gray-400 border
              <%= errors.email ? 'border-red-400 focus:ring-red-400/40' : 'border-white/20 focus:ring-red-400/30' %>
              focus:outline-none focus:ring-2 focus:border-transparent
              transition-all duration-300">

          <% if (errors.email) { %>
            <p class="text-red-400 text-xs px-2"><%= errors.email.msg %></p>
          <% } %>
        </div>

        <!-- Password -->
        <div class="space-y-1">
          <div class="relative">
            <input type="password" name="password" id="password" required
              placeholder="Enter your password"
              class="w-full rounded-xl bg-white/20 px-4 pr-12 py-3 text-sm text-white placeholder-gray-400 border
                <%= errors.password ? 'border-red-400 focus:ring-red-400/40' : 'border-white/20 focus:ring-red-400/30' %>
                focus:outline-none focus:ring-2 focus:border-transparent
                transition-all duration-300">

            <button type="button" id="togglePassword"
              class="absolute right-3 top-1/2 -translate-y-1/2
                     flex items-center justify-center
                     text-gray-400 hover:text-red-400
                     transition-all duration-300 hover:scale-110">
              <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7z"/>
              </svg>
            </button>
          </div>

          <% if (errors.password) { %>
            <p class="text-red-400 text-xs px-2"><%= errors.password.msg %></p>
          <% } %>
        </div>

        <!-- Confirm Password -->
        <div class="space-y-1">
          <input type="password" name="confirmPassword" required
            placeholder="Confirm password"
            class="w-full rounded-xl bg-white/20 px-4 py-3 text-sm text-white placeholder-gray-400 border
              <%= errors.confirmPassword ? 'border-red-400 focus:ring-red-400/40' : 'border-white/20 focus:ring-red-400/30' %>
              focus:outline-none focus:ring-2 focus:border-transparent
              transition-all duration-300">

          <% if (errors.confirmPassword) { %>
            <p class="text-red-400 text-xs px-2"><%= errors.confirmPassword.msg %></p>
          <% } %>
        </div>

        <!-- Role -->
        <div class="space-y-3 bg-white/10 p-4 rounded-xl border border-white/20">
          <label class="text-sm font-semibold text-gray-300">
            I want to register as:
          </label>

          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-lg 
                          hover:bg-white/10 transition-all duration-300 text-gray-300">
              <input type="radio" name="role" value="user"
                <%= oldInput.role === 'user' ? 'checked' : '' %>
                class="h-4 w-4 accent-red-500">
              <span class="text-sm font-medium">User</span>
            </label>

            <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-lg 
                          hover:bg-white/10 transition-all duration-300 text-gray-300">
              <input type="radio" name="role" value="host"
                <%= oldInput.role === 'host' ? 'checked' : '' %>
                class="h-4 w-4 accent-red-500">
              <span class="text-sm font-medium">Host</span>
            </label>
          </div>
        </div>

        <!-- Terms -->
        <div class="flex items-start gap-2 text-sm text-gray-400">
          <input type="checkbox" id="terms" name="terms" required
            class="mt-1 h-4 w-4 rounded border-white/20 bg-white/20 
                   accent-red-500 focus:ring-2 focus:ring-red-400/40">

          <label for="terms" class="cursor-pointer select-none">
            I agree to the
            <a href="/terms"
               class="font-medium text-red-400 hover:text-red-300 transition">
              Terms & Conditions
            </a>
          </label>
        </div>

        <!-- Submit -->
        <button type="submit"
          class="w-full rounded-xl py-3 
                 bg-gradient-to-r from-red-500 to-pink-500 
                 text-white font-semibold 
                 shadow-lg shadow-red-500/30
                 hover:shadow-red-500/50
                 hover:scale-[1.02]
                 active:scale-95
                 transition-all duration-300">
          Create Account
        </button>

      </form>

      <!-- Login -->
      <p class="text-center text-sm text-gray-400 mt-8">
        Already have an account?
        <a href="/login"
           class="font-semibold text-red-400 hover:text-red-300 transition">
          Login
        </a>
      </p>

    </div>
  </div>

  <!-- Toggle Password Script (UNCHANGED LOGIC) -->
  <script>
    const togglePassword = document.getElementById("togglePassword");
    const passwordInput = document.getElementById("password");
    const eyeIcon = document.getElementById("eyeIcon");

    togglePassword.addEventListener("click", () => {
      const isHidden = passwordInput.type === "password";
      passwordInput.type = isHidden ? "text" : "password";

      eyeIcon.innerHTML = isHidden
        ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                 d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a10.06 10.06 0 012.229-3.418M9.88 9.88a3 3 0 104.242 4.242M6.343 6.343l11.314 11.314"/>`
        : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                 d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                 d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`;
    });
  </script>

</body>
</html>