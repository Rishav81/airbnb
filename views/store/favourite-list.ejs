<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-slate-900 via-slate-950 to-black ">
<%- include('../partials/nav') %>

<section class="pt-28 pb-16 min-h-screen ">
  <div class="mx-auto w-full max-w-[90rem] px-6">

    <!-- Heading -->
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-xl md:text-3xl  font-extrabold tracking-tight text-white">
        My <span class="bg-gradient-to-r from-red-500 to-pink-500 
                 bg-clip-text text-transparent">Favourites</span>
      </h1>

      <!-- Info text -->
      <p class="mt-1 text-gray-500 text-xs md:text-base">
        All your favourite homes are saved here. Browse, view details, book your stay, or remove them from favourites.
      </p>
    </div>

    <!-- Empty state -->
    <% if (!registeredHomes || registeredHomes.length === 0) { %>
      <p class="text-center mt-10 text-gray-500 text-lg">
        You haven’t added any favourite homes yet ❤️
      </p>
    <% } else { %>

      <!-- Grid of favourite homes -->
      <ul class="mt-14 grid grid-cols-2 sm:grid-cols-3  lg:grid-cols-6 gap-6">

        <% registeredHomes.forEach(home => { %>
          <% const roundedRating = Math.round(home.houseRating); %>

          <li class="group flex flex-col 
           rounded-3xl 
           bg-white/[0.03] 
           border border-white/10
           shadow-lg shadow-black/40
           overflow-hidden
           hover:-translate-y-1
           hover:shadow-2xl hover:shadow-black/60
           transition-all duration-300 ease-out">

  <!-- Image -->
  <a href="/home-list/<%= home._id %>" 
     class="relative block overflow-hidden rounded-t-3xl">

    <img src="<%= home.houseImg %>"
         loading="lazy"
         alt="<%= home.houseName %>"
         class="w-full h-48 object-cover
                transition-transform duration-700 ease-out
                group-hover:scale-110">

    <!-- Smooth overlay -->
    <div class="absolute inset-0 
                bg-gradient-to-t 
                from-black/80 via-black/30 to-transparent
                opacity-90 group-hover:opacity-100
                transition duration-300">
    </div>

    <!-- Rating -->
    <div class="absolute top-3 left-3 
                bg-black/60 backdrop-blur-md
                px-2.5 py-1 
                rounded-full 
                flex items-center gap-1
                text-xs font-semibold text-white
                shadow-md shadow-black/40">

      <span class="text-yellow-400">★</span>
      <%= home.houseRating %>
    </div>

    <!-- Bottom Info -->
    <div class="absolute bottom-3 left-3 right-3 text-white">

      <h2 class="text-sm font-semibold line-clamp-1
                 group-hover:text-red-400
                 transition duration-300">
        <%= home.houseName %>
      </h2>

      <p class="text-xs text-gray-200 line-clamp-1 mt-1">
        📍 <%= home.houseLocation %>
      </p>

    </div>
  </a>

  <!-- Buttons -->
  <div class="p-4 flex flex-col gap-3">

    <form action="/remove-favourite/<%= home._id %>" 
          method="POST" class="flex-1">
      <button
        class="w-full py-2 text-sm font-medium
               border border-white/20
               text-gray-300
               rounded-xl
               hover:bg-white/10
               hover:text-white
               transition-all duration-300">
        Remove
      </button>
    </form>

    <a href="/home-list/<%= home._id %>"
       class="w-full py-2 text-sm font-semibold
              rounded-xl
              bg-gradient-to-r from-red-500 to-pink-500
              text-white text-center
              shadow-lg shadow-red-500/30
              hover:shadow-red-500/50
              hover:scale-[1.02]
              active:scale-95
              transition-all duration-300">
      Book Now
    </a>

  </div>

</li>
        <% }) %>

      </ul>
    <% } %>

  </div>
</section>


         
 <%-include ('../partials/footer')%>
</body>
</html>
